#!/usr/bin/env bash

############################################################################################
# UniFi OS Server SSL Import Script
# Certbot DNS-01 via Cloudflare only
############################################################################################

# Domain Name:
UNIFI_HOSTNAME="unifi.rippleffect.com"

# Scripr version/name:
SCRIPT_NAME="unifi-cert-import"
SCRIPT_VERSION="1.0.0"

# Certbot paths:
CERTBOT_CONFIG_DIR="/etc/letsencrypt"
CLOUDFLARE_CREDENTIALS="/root/.secrets/cloudflare.ini"

# UniFi OS Server certificate destination:
UNIFI_CERT_DIR="/home/uosserver/.local/share/containers/storage/volumes/uosserver_data/_data/unifi-core/config"
DEST_KEY="${UNIFI_CERT_DIR}/unifi-core.key"
DEST_CERT="${UNIFI_CERT_DIR}/unifi-core.crt"

# Certbot renewal behaviour:
RUN_CERTBOT_RENEW=true
CERTBOT_PROPAGATION_SECONDS=60

# Force Mode:
FORCE=false

# Verbose Mode:
VERBOSE=false

# Logging Mode:
LOGGING=true
#LOGFILE="/var/log/unifi-os-server-ssl-import.log"
LOGFILE="/var/log/scripts/unifi-cert-import.log"

############################################################################################

set -euo pipefail

usage() {
    echo "Usage: $0 [--force] [--verbose] [--no-log] [--no-renew]"
    echo
    echo "Options:"
    echo "  --force       Import certificate even if unchanged"
    echo "  --verbose     Show command output"
    echo "  --no-log      Disable logfile output"
    echo "  --no-renew    Skip certbot renew and only import existing cert"
}

for arg in "$@"; do
    case "$arg" in
        --force) FORCE=true ;;
        --verbose) VERBOSE=true ;;
        --no-log) LOGGING=false ;;
        --no-renew) RUN_CERTBOT_RENEW=false ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            echo "Unknown argument: $arg"
            usage
            exit 1
            ;;
    esac
done

if [[ "$LOGGING" == true ]]; then
    exec > >(tee -a "$LOGFILE") 2>&1
fi

run_command() {
    if [[ "$VERBOSE" == true ]]; then
        "$@"
    else
        "$@" >/dev/null 2>&1
    fi
}

fail() {
    echo "❌ $*"
    exit 1
}

echo "========================================"
echo " ${SCRIPT_NAME} v${SCRIPT_VERSION}"
echo "========================================"
echo " Run at: $(date)"
echo " Hostname: ${UNIFI_HOSTNAME}"
echo " DNS Provider: ${DNS_PROVIDER}"
echo " Certbot renew: ${RUN_CERTBOT_RENEW}"
echo " Logging: ${LOGGING}"
echo "========================================"

[[ "$EUID" -eq 0 ]] || fail "This script must be run as root."

command -v certbot >/dev/null 2>&1 || fail "certbot is not installed."
command -v openssl >/dev/null 2>&1 || fail "openssl is not installed."
command -v sha256sum >/dev/null 2>&1 || fail "sha256sum is not available."
command -v uosserver >/dev/null 2>&1 || fail "uosserver command not found."

[[ -d "$CERTBOT_CONFIG_DIR" ]] || fail "Certbot config directory not found: $CERTBOT_CONFIG_DIR"
[[ -f "$CLOUDFLARE_CREDENTIALS" ]] || fail "Cloudflare credentials file not found: $CLOUDFLARE_CREDENTIALS"
[[ -d "$UNIFI_CERT_DIR" ]] || fail "UniFi cert destination directory not found: $UNIFI_CERT_DIR"

CRED_PERMS=$(stat -c "%a" "$CLOUDFLARE_CREDENTIALS")
if [[ "$CRED_PERMS" != "600" ]]; then
    echo "⚠️  Cloudflare credentials file permissions are ${CRED_PERMS}; expected 600."
    echo "    Fixing permissions..."
    chmod 600 "$CLOUDFLARE_CREDENTIALS"
fi

CERT_DIR="${CERTBOT_CONFIG_DIR}/live/${UNIFI_HOSTNAME}"
CERT_FILE="${CERT_DIR}/cert.pem"
CHAIN_FILE="${CERT_DIR}/chain.pem"
FULLCHAIN_FILE="${CERT_DIR}/fullchain.pem"
KEY_FILE="${CERT_DIR}/privkey.pem"
COMBINED_HASH_FILE="${CERT_DIR}/cert_bundle.sha256"

if [[ "$RUN_CERTBOT_RENEW" == true ]]; then
    echo "Running Certbot renewal via Cloudflare DNS..."
    run_command certbot renew \
        --dns-cloudflare \
        --dns-cloudflare-credentials "$CLOUDFLARE_CREDENTIALS" \
        --dns-cloudflare-propagation-seconds "$CERTBOT_PROPAGATION_SECONDS"
    echo "✅ Certbot renewal check completed."
fi

echo "Checking required certificate files in ${CERT_DIR}..."

[[ -f "$KEY_FILE" ]] || fail "Missing private key file: $KEY_FILE"
[[ -f "$CERT_FILE" ]] || fail "Missing certificate file: $CERT_FILE"
[[ -f "$CHAIN_FILE" ]] || fail "Missing chain file: $CHAIN_FILE"
[[ -f "$FULLCHAIN_FILE" ]] || fail "Missing fullchain file: $FULLCHAIN_FILE"

echo "✅ All required certificate files found."

CURRENT_SUM=$(cat "$KEY_FILE" "$FULLCHAIN_FILE" | sha256sum | awk '{print $1}')
echo "Current cert bundle SHA256: $CURRENT_SUM"

if [[ "$FORCE" == false && -f "$COMBINED_HASH_FILE" ]]; then
    OLD_SUM=$(<"$COMBINED_HASH_FILE")
    echo "Previous cert bundle SHA256: $OLD_SUM"

    if [[ "$CURRENT_SUM" == "$OLD_SUM" ]]; then
        echo "✅ Certificate unchanged. No update necessary."
        exit 0
    fi
fi

echo "Certificate changed or --force used. Proceeding with UniFi import."

BACKUP_SUFFIX="$(date +%Y%m%d-%H%M%S)"

echo "Stopping UniFi OS Server..."
run_command uosserver stop
echo "✅ UniFi stopped."

if [[ -f "$DEST_KEY" ]]; then
    cp -a "$DEST_KEY" "${DEST_KEY}.bak-${BACKUP_SUFFIX}"
    echo "✅ Existing key backed up."
fi

if [[ -f "$DEST_CERT" ]]; then
    cp -a "$DEST_CERT" "${DEST_CERT}.bak-${BACKUP_SUFFIX}"
    echo "✅ Existing cert backed up."
fi

echo "Installing new private key..."
cp "$KEY_FILE" "$DEST_KEY"

echo "Installing new fullchain certificate..."
cp "$FULLCHAIN_FILE" "$DEST_CERT"

echo "Setting ownership and permissions..."
chown root:uosserver "$DEST_KEY" "$DEST_CERT"
chmod 640 "$DEST_KEY" "$DEST_CERT"

echo "$CURRENT_SUM" > "$COMBINED_HASH_FILE"
chmod 600 "$COMBINED_HASH_FILE"

echo "Installed certificate details:"
openssl x509 -in "$DEST_CERT" -noout -subject -issuer -serial -enddate

echo "Starting UniFi OS Server..."
run_command uosserver start
echo "✅ UniFi started."

echo "✅ Done. SSL cert imported into UniFi OS Server."
exit 0
